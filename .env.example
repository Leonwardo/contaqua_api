# ============================================
# Contaqua API v2 - Environment Configuration
# ============================================

# Application
APP_NAME=ContaquaAPI
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=Europe/Lisbon

# MongoDB Configuration
MONGO_URI=mongodb://127.0.0.1:27017
MONGO_DATABASE=contaqua
MONGO_USERNAME=
MONGO_PASSWORD=

# Admin Configuration
ADMIN_TOKEN=change_this_to_a_secure_random_token
ADMIN_SESSION_TIMEOUT=3600

# Security
CORS_ORIGIN=*
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Logging
LOG_LEVEL=debug
LOG_PATH=logs/app.log
LOG_MAX_FILES=30

# Uploads
UPLOAD_MAX_SIZE=10485760
UPLOAD_PATH=storage/uploads/

# Android App Compatibility
# These settings ensure compatibility with the Android MeterApp
LEGACY_AUTH_MODE=true
ALLOW_LEGACY_PLAIN_PASSWORDS=false
