# ============================================
# Contaqua API v2 - Environment Configuration
# ============================================

# Application
APP_NAME=ContaquaAPI
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=Europe/Lisbon

# MongoDB Configuration
# Para MongoDB Atlas (quando DNS funcionar):
# MONGO_URI=mongodb+srv://ruimeskuita_db_user:Fgv5h6j9n7LXGEOG@cluster0.q338oqb.mongodb.net/contaqua_meter?retryWrites=true&w=majority
# MONGO_DATABASE=contaqua_meter
#
# Para MongoDB local (XAMPP/WAMP):
MONGO_URI=mongodb://127.0.0.1:27017
MONGO_DATABASE=contaqua
MONGO_USERNAME=
MONGO_PASSWORD=

# Admin Configuration
ADMIN_TOKEN=admin_secret_token_2024
ADMIN_SESSION_TIMEOUT=3600

# Security
CORS_ORIGIN=*
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Logging
LOG_LEVEL=debug
LOG_PATH=logs/app.log
LOG_MAX_FILES=30

# Uploads
UPLOAD_MAX_SIZE=10485760
UPLOAD_PATH=storage/uploads/

# Android App Compatibility
LEGACY_AUTH_MODE=true
ALLOW_LEGACY_PLAIN_PASSWORDS=false
